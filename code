# Agent 3: 基本面分析
# =========================

class FundamentalAnalysisAgent:
    def __init__(self, ticker: str):
        self.ticker = ticker

    @staticmethod
    def _score_valuation(trailing_pe: Optional[float], forward_pe: Optional[float], price_to_book: Optional[float]) -> float:
        score = 0.0
        count = 0
        if trailing_pe is not None:
            count += 1
            if trailing_pe <= 10:
                score += 1.0
            elif trailing_pe <= 20:
                score += 0.5
            elif trailing_pe <= 35:
                score += 0.0
            else:
                score -= 0.5
        if forward_pe is not None:
            count += 1
            if forward_pe <= 10:
                score += 1.0
            elif forward_pe <= 20:
                score += 0.5
            elif forward_pe <= 35:
                score += 0.0
            else:
                score -= 0.5
        if price_to_book is not None:
            count += 1
            if price_to_book <= 1.5:
                score += 0.8
            elif price_to_book <= 3:
                score += 0.4
            elif price_to_book <= 6:
                score += 0.0
            else:
                score -= 0.4
        if count == 0:
            return 50.0
        score = score / count
        return round((clip(score, -1, 1) + 1) * 50, 2)

    @staticmethod
    def _score_profitability(profit_margin: Optional[float], operating_margin: Optional[float], roe: Optional[float]) -> float:
        vals = [v for v in [profit_margin, operating_margin, roe] if v is not None]
        if not vals:
            return 50.0
        score = 0.0
        for v in vals:
            if v >= 0.25:
                score += 1.0
            elif v >= 0.10:
                score += 0.5
            elif v >= 0:
                score += 0.0
            else:
                score -= 0.8
        score /= len(vals)
        return round((clip(score, -1, 1) + 1) * 50, 2)

    @staticmethod
    def _score_leverage(debt_to_equity: Optional[float], current_ratio: Optional[float]) -> float:
        score = 0.0
        count = 0
        if debt_to_equity is not None:
            count += 1
            if debt_to_equity <= 0.5:
                score += 1.0
            elif debt_to_equity <= 1.0:
                score += 0.5
            elif debt_to_equity <= 2.0:
                score += 0.0
            else:
                score -= 0.7
        if current_ratio is not None:
            count += 1
            if current_ratio >= 2.0:
                score += 0.7
            elif current_ratio >= 1.2:
                score += 0.4
            elif current_ratio >= 1.0:
                score += 0.0
            else:
                score -= 0.5
        if count == 0:
            return 50.0
        score /= count
        return round((clip(score, -1, 1) + 1) * 50, 2)

    @staticmethod
    def _score_growth(earnings_growth: Optional[float], revenue_growth: Optional[float]) -> float:
        vals = [v for v in [earnings_growth, revenue_growth] if v is not None]
        if not vals:
            return 50.0
        score = 0.0
        for v in vals:
            if v >= 0.20:
                score += 1.0
            elif v >= 0.10:
                score += 0.5
            elif v >= 0:
                score += 0.0
            else:
                score -= 0.6
        score /= len(vals)
        return round((clip(score, -1, 1) + 1) * 50, 2)

    def run(self) -> FundamentalResult:
        t = yf.Ticker(self.ticker)
        info: Dict[str, Any] = {}
        try:
            info = t.info or {}
        except Exception:
            info = {}

        trailing_pe = safe_float(info.get("trailingPE"))
        forward_pe = safe_float(info.get("forwardPE"))
        price_to_book = safe_float(info.get("priceToBook"))
        profit_margin = safe_float(info.get("profitMargins"))
        operating_margin = safe_float(info.get("operatingMargins"))
        roe = safe_float(info.get("returnOnEquity"))
        debt_to_equity = safe_float(info.get("debtToEquity"))
        current_ratio = safe_float(info.get("currentRatio"))
        earnings_growth = safe_float(info.get("earningsGrowth"))
        revenue_growth = safe_float(info.get("revenueGrowth"))

        valuation_score = self._score_valuation(trailing_pe, forward_pe, price_to_book)
        profitability_score = self._score_profitability(profit_margin, operating_margin, roe)
        leverage_score = self._score_leverage(debt_to_equity, current_ratio)
        growth_score = self._score_growth(earnings_growth, revenue_growth)

        # 数据质量：可用字段比例
        fields = [
            trailing_pe,
            forward_pe,
            price_to_book,
            profit_margin,
            operating_margin,
            roe,
            debt_to_equity,
            current_ratio,
            earnings_growth,
            revenue_growth,
        ]
        data_quality = round(100 * sum(v is not None for v in fields) / len(fields), 2)

        # 基本面综合：盈利 > 成长 > 估值 > 负债
        score = (
            0.30 * valuation_score
            + 0.30 * profitability_score
            + 0.20 * growth_score
            + 0.20 * leverage_score
        )
        summary = (
            f"基本面：PE={trailing_pe if trailing_pe is not None else 'N/A'}，ForwardPE={forward_pe if forward_pe is not None else 'N/A'}，"
            f"PB={price_to_book if price_to_book is not None else 'N/A'}，利润率={to_pct(profit_margin)}，"
            f"ROE={to_pct(roe)}，资产负债={debt_to_equity if debt_to_equity is not None else 'N/A'}，"
            f"流动比率={current_ratio if current_ratio is not None else 'N/A'}，"
            f"增长={to_pct(earnings_growth)} / {to_pct(revenue_growth)}。"
            f"综合基本面评分={score:.2f}/100，数据质量={data_quality:.2f}%。"
        )

        return FundamentalResult(
            ticker=self.ticker,
            score=round(score, 2),
            valuation_score=valuation_score,
            profitability_score=profitability_score,
            leverage_score=leverage_score,
            growth_score=growth_score,
            data_quality=data_quality,
            summary=summary,
        )


