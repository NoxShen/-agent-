# Agent 2: 技术分析
# =========================

class TechnicalAnalysisAgent:
    def __init__(self, ticker: str, bench_close: Optional[pd.Series] = None):
        self.ticker = ticker
        self.bench_close = bench_close

    @staticmethod
    def _rsi(close: pd.Series, period: int = 14) -> pd.Series:
        delta = close.diff()
        gain = delta.clip(lower=0)
        loss = -delta.clip(upper=0)
        avg_gain = gain.ewm(alpha=1 / period, min_periods=period, adjust=False).mean()
        avg_loss = loss.ewm(alpha=1 / period, min_periods=period, adjust=False).mean()
        rs = avg_gain / avg_loss.replace(0, np.nan)
        rsi = 100 - (100 / (1 + rs))
        return rsi

    @staticmethod
    def _ema(series: pd.Series, span: int) -> pd.Series:
        return series.ewm(span=span, adjust=False).mean()

    def run(self, df: pd.DataFrame) -> TechnicalResult:
        close = df["Close"].astype(float)
        ret = close.pct_change()

        sma20 = close.rolling(20).mean()
        sma60 = close.rolling(60).mean()
        ema12 = self._ema(close, 12)
        ema26 = self._ema(close, 26)
        macd = ema12 - ema26
        macd_signal = self._ema(macd, 9)
        macd_hist = macd - macd_signal
        rsi = self._rsi(close, 14)

        last_close = float(close.iloc[-1])
        last_sma20 = latest_non_nan(sma20)
        last_sma60 = latest_non_nan(sma60)
        last_rsi = latest_non_nan(rsi)
        last_macd_hist = latest_non_nan(macd_hist)

        # 趋势分：20日均线 > 60日均线 且 价格在20日均线之上
        trend_score = 0.0
        if last_sma20 is not None and last_sma60 is not None:
            trend_score += 0.6 if last_sma20 > last_sma60 else -0.6
        if last_sma20 is not None:
            trend_score += 0.4 if last_close > last_sma20 else -0.4
        trend_score = clip(trend_score, -1, 1)

        # 动量分：近20日收益
        mom20 = float(close.iloc[-1] / close.iloc[-21] - 1) if len(close) >= 21 else np.nan
        momentum_score = clip((mom20 / 0.1) if not np.isnan(mom20) else 0.0, -1, 1)

        # RSI分：40-60中性，低于30偏低，>70偏高
        rsi_score = 0.0
        if last_rsi is not None:
            if last_rsi < 30:
                rsi_score = 0.8
            elif last_rsi < 40:
                rsi_score = 0.3
            elif last_rsi <= 60:
                rsi_score = 0.0
            elif last_rsi <= 70:
                rsi_score = -0.3
            else:
                rsi_score = -0.8

        # MACD柱体分：正为多，负为空
        macd_score = 0.0
        if last_macd_hist is not None:
            macd_score = clip(last_macd_hist / (close.std() + 1e-9) * 20, -1, 1)

        # 相对强弱：相对基准近20日收益
        relative_strength_score = 0.0
        if self.bench_close is not None and len(self.bench_close) >= 21 and len(close) >= 21:
            asset_20 = float(close.iloc[-1] / close.iloc[-21] - 1)
            bench_20 = float(self.bench_close.iloc[-1] / self.bench_close.iloc[-21] - 1)
            rs = asset_20 - bench_20
            relative_strength_score = clip(rs / 0.1, -1, 1)

        # 波动率惩罚：越高越减分
        ann_vol = annualized_volatility(ret)
        volatility_penalty = 0.0 if np.isnan(ann_vol) else clip((ann_vol - 0.25) / 0.30, 0, 1)

        raw = (
            0.30 * trend_score
            + 0.20 * momentum_score
            + 0.20 * rsi_score
            + 0.15 * macd_score
            + 0.15 * relative_strength_score
        )
        score = clip(raw - 0.25 * volatility_penalty, -1, 1)
        score_100 = round((score + 1) * 50, 2)

        summary = (
            f"技术面：趋势={trend_score:.2f}，动量={momentum_score:.2f}，RSI={rsi_score:.2f}，"
            f"MACD={macd_score:.2f}，相对强弱={relative_strength_score:.2f}，波动惩罚={volatility_penalty:.2f}。"
            f"综合技术评分={score_100}/100。"
        )

        return TechnicalResult(
            ticker=self.ticker,
            score=score_100,
            trend_score=round((trend_score + 1) * 50, 2),
            momentum_score=round((momentum_score + 1) * 50, 2),
            rsi_score=round((rsi_score + 1) * 50, 2),
            macd_score=round((macd_score + 1) * 50, 2),
            relative_strength_score=round((relative_strength_score + 1) * 50, 2),
            volatility_penalty=round(volatility_penalty * 100, 2),
            summary=summary,
        )


