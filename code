class SynthesisAgent:
    @staticmethod
    def _to_bias(score: float) -> str:
        if score >= 70:
            return "偏多"
        if score >= 55:
            return "温和偏多"
        if score >= 45:
            return "中性"
        if score >= 30:
            return "温和偏空"
        return "偏空"

    @staticmethod
    def _to_action(overall: float, risk: RiskResult) -> str:
        if overall >= 70 and risk.suggested_position_pct <= 20:
            return "可小仓试探"
        if overall >= 60:
            return "观察后分批介入"
        if overall >= 45:
            return "继续观察，等待确认"
        return "谨慎规避或降低仓位"

    def run(
        self,
        ticker: str,
        technical: TechnicalResult,
        fundamental: FundamentalResult,
        sentiment: SentimentResult,
        risk: RiskResult,
    ) -> FinalResult:
        # 权重：技术 35%，基本面 30%，情绪 15%，风险 20%
        # 风险这里不是“越大越好”，所以先转成风险安全分
        risk_safety = clip(100 - (risk.suggested_stop_loss_pct * 2 + abs(risk.max_drawdown) * 100 * 1.5 if not np.isnan(risk.max_drawdown) else 20), 0, 100)

        overall = (
            0.35 * technical.score
            + 0.30 * fundamental.score
            + 0.15 * sentiment.score
            + 0.20 * risk_safety
        )

        # 数据质量影响置信度
        confidence = clip(
            0.35 * (fundamental.data_quality / 100)
            + 0.25 * (sentiment.headline_count / 10 if sentiment.headline_count else 0.0)
            + 0.40 * 1.0,
            0,
            1,
        )
        confidence = round(confidence * 100, 2)

        bias = self._to_bias(overall)
        action = self._to_action(overall, risk)

        return FinalResult(
            ticker=ticker,
            overall_score=round(overall, 2),
            bias=bias,
            confidence=confidence,
            action=action,
            technical=technical,
            fundamental=fundamental,
            sentiment=sentiment,
            risk=risk,
        )


