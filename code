class ReportAgent:
    @staticmethod
    def render_single(result: FinalResult, last_price: float, currency: str = "") -> str:
        md = []
        md.append(f"# {result.ticker} 多 Agent 分析报告")
        md.append("")
        md.append(f"- 最新价格：{last_price:.4f} {currency}".rstrip())
        md.append(f"- 综合评分：**{result.overall_score:.2f}/100**")
        md.append(f"- 方向判断：**{result.bias}**")
        md.append(f"- 置信度：**{result.confidence:.2f}%**")
        md.append(f"- 操作建议：**{result.action}**")
        md.append("")
        md.append("## 各 Agent 结论")
        md.append("")
        md.append(f"**技术面**：{result.technical.summary}")
        md.append("")
        md.append(f"**基本面**：{result.fundamental.summary}")
        md.append("")
        md.append(f"**情绪面**：{result.sentiment.summary}")
        md.append("")
        md.append(f"**风险面**：{result.risk.summary}")
        md.append("")
        md.append("## 结构化输出")
        md.append("")
        md.append("```json")
        md.append(json.dumps(asdict(result), ensure_ascii=False, indent=2, default=str))
        md.append("```")
        return "\n".join(md)

    @staticmethod
    def render_ranking(results: List[FinalResult]) -> str:
        lines = ["# 股票排名（综合分）", ""]
        ranked = sorted(results, key=lambda r: r.overall_score, reverse=True)
        for i, r in enumerate(ranked, 1):
            lines.append(f"{i}. {r.ticker} — {r.overall_score:.2f}/100，{r.bias}，{r.action}")
        return "\n".join(lines)


