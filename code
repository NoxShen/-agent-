# 协调器
# =========================

class MultiAgentStockAnalyzer:
    def __init__(self, benchmark: str = "SPY", period: str = "1y", interval: str = "1d", capital: float = 100000.0, risk_pct: float = 0.01):
        self.benchmark = benchmark
        self.period = period
        self.interval = interval
        self.capital = capital
        self.risk_pct = risk_pct

    def _fetch_benchmark(self) -> Optional[pd.DataFrame]:
        try:
            df = yf.download(
                self.benchmark,
                period=self.period,
                interval=self.interval,
                auto_adjust=False,
                progress=False,
                threads=False,
            )
            if df is None or df.empty:
                return None
            df = df.copy()
            df.columns = [c.title() for c in df.columns]
            if "Close" not in df.columns:
                return None
            return df
        except Exception:
            return None

    def analyze(self, ticker: str) -> Tuple[FinalResult, pd.DataFrame]:
        market_agent = MarketDataAgent(ticker, period=self.period, interval=self.interval)
        df = market_agent.run()

        bench_df = self._fetch_benchmark()
        bench_close = bench_df["Close"] if bench_df is not None and "Close" in bench_df.columns else None

        technical = TechnicalAnalysisAgent(ticker, bench_close=bench_close).run(df)
        fundamental = FundamentalAnalysisAgent(ticker).run()
        sentiment = SentimentAnalysisAgent(ticker).run()
        risk = RiskManagementAgent(ticker, bench_close=bench_close, capital=self.capital, risk_pct=self.risk_pct).run(df)
        final = SynthesisAgent().run(ticker, technical, fundamental, sentiment, risk)
        return final, df

    def analyze_many(self, tickers: List[str]) -> List[Tuple[FinalResult, pd.DataFrame]]:
        outputs = []
        for ticker in tickers:
            try:
                outputs.append(self.analyze(ticker))
            except Exception as e:
                print(f"[WARN] {ticker} 分析失败：{e}", file=sys.stderr)
        return outputs


# =========================
# CLI
# =========================

def build_arg_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="多 Agent 股票 / 投资分析 Agent")
    p.add_argument("--tickers", nargs="+", required=True, help="股票代码列表，例如 AAPL MSFT 600519.SS")
    p.add_argument("--benchmark", default="SPY", help="基准指数/ETF，例如 SPY, 000300.SS")
    p.add_argument("--period", default="1y", help="行情周期，例如 6mo, 1y, 2y, max")
    p.add_argument("--interval", default="1d", help="K 线周期，例如 1d, 1wk, 1h")
    p.add_argument("--capital", type=float, default=100000.0, help="假设资金规模，用于仓位建议")
    p.add_argument("--risk-pct", type=float, default=0.01, help="单笔最大风险比例，例如 0.01 = 1%")
    p.add_argument("--output", default="", help="输出 Markdown 报告文件路径")
    p.add_argument("--json-output", default="", help="输出 JSON 文件路径")
    return p


def main() -> None:
    args = build_arg_parser().parse_args()

    analyzer = MultiAgentStockAnalyzer(
        benchmark=args.benchmark,
        period=args.period,
        interval=args.interval,
        capital=args.capital,
        risk_pct=args.risk_pct,
    )

    analyzed: List[Tuple[FinalResult, pd.DataFrame]] = analyzer.analyze_many(args.tickers)
    if not analyzed:
        print("没有成功分析任何标的。", file=sys.stderr)
        sys.exit(1)

    results = [x[0] for x in analyzed]
    ranked = sorted(results, key=lambda r: r.overall_score, reverse=True)

    # 控制台输出
    print("\n=== 综合排名 ===")
    for i, r in enumerate(ranked, 1):
        print(f"{i}. {r.ticker}: {r.overall_score:.2f}/100 | {r.bias} | {r.action}")

    # 单票详细报告
    print("\n=== 详细报告 ===")
    for result, df in analyzed:
        last_price = float(df["Close"].iloc[-1])
        currency = ""
        try:
            info = yf.Ticker(result.ticker).fast_info
            # fast_info 的 currency 不一定可用，做个兼容
            currency = getattr(info, "currency", "") if info else ""
        except Exception:
            currency = ""

        report_md = ReportAgent.render_single(result, last_price=last_price, currency=currency)
        print(report_md)
        print("\n" + "=" * 80 + "\n")

        if args.output:
            # 多票时，按 ticker 分文件保存
            if len(analyzed) == 1:
                out_path = args.output
            else:
                base = args.output.rsplit(".", 1)[0]
                ext = args.output.rsplit(".", 1)[1] if "." in args.output else "md"
                out_path = f"{base}_{result.ticker}.{ext}"
            with open(out_path, "w", encoding="utf-8") as f:
                f.write(report_md)
            print(f"[OK] Markdown 报告已保存：{out_path}")

    if args.json_output:
        payload = {
            "benchmark": args.benchmark,
            "period": args.period,
            "interval": args.interval,
            "capital": args.capital,
            "risk_pct": args.risk_pct,
            "generated_at": datetime.now().isoformat(),
            "results": [asdict(r) for r in ranked],
        }
        with open(args.json_output, "w", encoding="utf-8") as f:
            json.dump(payload, f, ensure_ascii=False, indent=2, default=str)
        print(f"[OK] JSON 报告已保存：{args.json_output}")

    # 输出排名 Markdown（可直接复制）
    print("\n=== 排名 Markdown ===")
    print(ReportAgent.render_ranking(ranked))


if __name__ == "__main__":
    main()
