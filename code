# Agent 5: 风险控制
# =========================

class RiskManagementAgent:
    def __init__(self, ticker: str, bench_close: Optional[pd.Series] = None, capital: float = 100000.0, risk_pct: float = 0.01):
        self.ticker = ticker
        self.bench_close = bench_close
        self.capital = capital
        self.risk_pct = risk_pct

    def run(self, df: pd.DataFrame) -> RiskResult:
        close = df["Close"].astype(float)
        high = df["High"].astype(float)
        low = df["Low"].astype(float)
        ret = close.pct_change()
        bench_ret = None
        if self.bench_close is not None:
            bench_ret = self.bench_close.pct_change()

        # ATR
        prev_close = close.shift(1)
        tr = pd.concat([
            high - low,
            (high - prev_close).abs(),
            (low - prev_close).abs(),
        ], axis=1).max(axis=1)
        atr14 = tr.rolling(14).mean()
        last_atr = latest_non_nan(atr14)
        last_close = float(close.iloc[-1])
        atr_pct = None if last_atr is None else last_atr / last_close

        ann_vol = annualized_volatility(ret)
        mdd = max_drawdown(close)
        var_5d = hist_var(ret, 0.05)
        beta = rolling_beta(ret, bench_ret) if bench_ret is not None else np.nan

        # 止损建议：2 ATR 或 6% 取更大者（更保守）
        stop_loss_pct = 0.06
        if atr_pct is not None and not np.isnan(atr_pct):
            stop_loss_pct = max(0.06, min(0.15, 2.0 * atr_pct))

        # 仓位建议：按风险预算 / 止损距离
        # 例如 1% 风险预算，若止损 6%，则仓位约 16.7%
        if stop_loss_pct <= 0:
            suggested_position_pct = 0.0
        else:
            suggested_position_pct = min(0.30, self.risk_pct / stop_loss_pct)

        # 风险分：越低风险越高分
        risk_penalty = 0.0
        if not np.isnan(ann_vol):
            risk_penalty += clip((ann_vol - 0.20) / 0.35, 0, 1)
        if not np.isnan(mdd):
            risk_penalty += clip((abs(mdd) - 0.10) / 0.30, 0, 1)
        if not np.isnan(var_5d):
            risk_penalty += clip((abs(var_5d) - 0.03) / 0.12, 0, 1)
        risk_penalty = risk_penalty / 3.0 if risk_penalty else 0.0

        summary = (
            f"风险：年化波动={to_pct(ann_vol)}，最大回撤={to_pct(mdd)}，5%日VaR={to_pct(var_5d)}，"
            f"beta={beta if not np.isnan(beta) else 'N/A'}，建议止损={to_pct(stop_loss_pct)}，"
            f"建议单票仓位上限≈{to_pct(suggested_position_pct)}。"
        )
        return RiskResult(
            ticker=self.ticker,
            annual_vol=round(ann_vol, 4) if not np.isnan(ann_vol) else np.nan,
            max_drawdown=round(mdd, 4) if not np.isnan(mdd) else np.nan,
            var_5d=round(var_5d, 4) if not np.isnan(var_5d) else np.nan,
            beta=round(beta, 4) if not np.isnan(beta) else np.nan,
            suggested_stop_loss_pct=round(stop_loss_pct * 100, 2),
            suggested_position_pct=round(suggested_position_pct * 100, 2),
            summary=summary,
        )


