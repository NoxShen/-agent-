# =========================
# 工具函数
# =========================

def safe_float(x: Any) -> Optional[float]:
    try:
        if x is None:
            return None
        if isinstance(x, str) and x.strip() == "":
            return None
        val = float(x)
        if math.isnan(val) or math.isinf(val):
            return None
        return val
    except Exception:
        return None


def to_pct(x: Optional[float], digits: int = 2) -> str:
    if x is None:
        return "N/A"
    return f"{x * 100:.{digits}f}%"


def clip(x: float, lo: float, hi: float) -> float:
    return max(lo, min(hi, x))


def latest_non_nan(series: pd.Series) -> Optional[float]:
    s = series.dropna()
    if s.empty:
        return None
    return float(s.iloc[-1])


def max_drawdown(close: pd.Series) -> float:
    if close is None or len(close) < 2:
        return np.nan
    cummax = close.cummax()
    dd = close / cummax - 1.0
    return float(dd.min())


def annualized_volatility(returns: pd.Series, trading_days: int = 252) -> float:
    if returns is None or len(returns.dropna()) < 2:
        return np.nan
    return float(returns.std(ddof=0) * np.sqrt(trading_days))


def hist_var(returns: pd.Series, alpha: float = 0.05) -> float:
    if returns is None or len(returns.dropna()) < 10:
        return np.nan
    return float(np.quantile(returns.dropna(), alpha))


def rolling_beta(asset_ret: pd.Series, bench_ret: pd.Series) -> float:
    df = pd.concat([asset_ret, bench_ret], axis=1).dropna()
    if len(df) < 20:
        return np.nan
    a = df.iloc[:, 0]
    b = df.iloc[:, 1]
    var_b = b.var(ddof=0)
    if var_b == 0 or np.isnan(var_b):
        return np.nan
    return float(np.cov(a, b, ddof=0)[0, 1] / var_b)


