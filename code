class SentimentAnalysisAgent:
    POSITIVE = {
        "beat", "beats", "surge", "surges", "upgrade", "upgrades", "record", "strong", "growth",
        "profit", "profits", "buy", "outperform", "rise", "rises", "rally", "expands", "expansion",
        "improves", "improvement", "positive", "acquire", "secures", "approval", "approved", "guidance raise",
        "创新", "增长", "盈利", "改善", "利好", "上涨", "突破", "超预期", "中标", "订单", "回购",
    }
    NEGATIVE = {
        "miss", "misses", "downgrade", "downgrades", "decline", "falls", "fall", "loss", "losses",
        "weak", "warning", "cut", "cuts", "slump", "slumps", "pressure", "lawsuit", "investigation",
        "delay", "delays", "negative", "bankrupt", "fraud", "risk", "concern", "concerns", "guidance cut",
        "下跌", "亏损", "减持", "调查", "诉讼", "风险", "下调", "暴跌", "延期", "停牌", "违约",
    }

    def __init__(self, ticker: str):
        self.ticker = ticker

    @staticmethod
    def _score_text(text: str) -> int:
        t = text.lower()
        pos = sum(1 for w in SentimentAnalysisAgent.POSITIVE if w.lower() in t)
        neg = sum(1 for w in SentimentAnalysisAgent.NEGATIVE if w.lower() in t)
        return pos - neg

    def run(self) -> SentimentResult:
        t = yf.Ticker(self.ticker)
        headlines: List[str] = []
        try:
            news = t.news or []
            for item in news[:10]:
                title = item.get("title") or item.get("headline")
                if title:
                    headlines.append(str(title))
        except Exception:
            headlines = []

        if not headlines:
            summary = "情绪面：未获取到足够新闻标题，默认中性。"
            return SentimentResult(
                ticker=self.ticker,
                score=50.0,
                headline_count=0,
                positive_hits=0,
                negative_hits=0,
                summary=summary,
            )

        pos_hits = 0
        neg_hits = 0
        total = 0
        for h in headlines:
            s = self._score_text(h)
            if s > 0:
                pos_hits += s
            elif s < 0:
                neg_hits += abs(s)
            total += s

        # 映射到 0-100
        score = clip(50 + total * 10, 0, 100)
        summary = (
            f"情绪面：抓取到 {len(headlines)} 条标题，正向命中 {pos_hits}，负向命中 {neg_hits}，"
            f"综合情绪评分={score:.2f}/100。"
        )
        return SentimentResult(
            ticker=self.ticker,
            score=round(score, 2),
            headline_count=len(headlines),
            positive_hits=pos_hits,
            negative_hits=neg_hits,
            summary=summary,
        )


